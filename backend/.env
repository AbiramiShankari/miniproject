# PrepTalk Backend — Environment Variables
# ─────────────────────────────────────────
# Fill in actual values and restart the server.

# MongoDB Connection
# Local: mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017

# Database Names (kept separate per domain)
MONGO_DB_INTERVIEWS=preptalk_interviews
MONGO_DB_ATS=preptalk_ats
MONGO_DB_PRACTICE=preptalk_practice

